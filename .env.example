# Copy to .env and fill in. .env is gitignored: never commit real secrets.

# --- CSFloat ---------------------------------------------------------------
# Generate at https://csfloat.com/profile  ->  "developer" tab
CSFLOAT_API_KEY=

# --- Steam (optional: auto-discover holdings) ------------------------------
# Your 64-bit SteamID (https://steamid.io). Inventory must be PUBLIC.
STEAM_ID64=
# Inspect/float API base (resolves float from inspect links)
CSFLOAT_INSPECT_BASE=https://api.csgofloat.com

# --- Email alerts (SMTP) ---------------------------------------------------
# Gmail:   smtp.gmail.com / 587  + a Google App Password (not your login pw)
# Outlook: smtp.office365.com / 587
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=
MAIL_TO=

# --- Behaviour -------------------------------------------------------------
POLL_SECONDS=900
DIVERGENCE_PCT=0.10
COOLDOWN_SECONDS=21600

# --- Hunt (flip finder: skins you don't own) -------------------------------
HUNT_MIN_PRICE_CENTS=2000     # $20 floor
HUNT_MAX_PRICE_CENTS=20000    # $200 ceiling
HUNT_MIN_MARGIN=0.15          # required ROI after fee
HUNT_SELL_FEE=0.02            # CSFloat seller fee, verify current rate
HUNT_MIN_LIQUIDITY=8          # min comps to trust + resell
HUNT_MAX_CANDIDATES=40        # cap candidates evaluated per run
